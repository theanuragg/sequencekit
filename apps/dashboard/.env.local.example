# ═══════════════════════════════════════════════════════════════
# SequenceKit Dashboard — Environment Variables
# Copy this file to .env.local and fill in each value.
# ═══════════════════════════════════════════════════════════════

# ── Solana ────────────────────────────────────────────────────
# RPC endpoint (devnet for development, mainnet-beta for production)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# MicroCLOB program ID — set after: anchor deploy --provider.cluster devnet
NEXT_PUBLIC_PROGRAM_ID=D2hmjC142DkGTZg8u8EXig3Kxci3nU7Qo8WLvwzrfoie

# Market PDA address — set after: npx tsx scripts/init-market.ts
NEXT_PUBLIC_MARKET_ADDRESS=

# ── Jito Block Engine ─────────────────────────────────────────
# Choose the region closest to you for lowest latency:
#   Amsterdam: https://amsterdam.mainnet.block-engine.jito.wtf
#   Frankfurt:  https://frankfurt.mainnet.block-engine.jito.wtf
#   New York:   https://ny.mainnet.block-engine.jito.wtf
#   Tokyo:      https://tokyo.mainnet.block-engine.jito.wtf
NEXT_PUBLIC_BLOCK_ENGINE_URL=https://amsterdam.mainnet.block-engine.jito.wtf

# ── ShredStream (Step 6) ──────────────────────────────────────
# Apply for access: https://forms.gle/BrKgmkHDHRQJFH7g7
# Mention: SequenceKit, Jito Hackathon 2025, BAM plugin project
# Test connection: npx tsx scripts/apply-shredstream.ts
#
# Once approved, Jito provides a WebSocket endpoint and auth token:
SHREDSTREAM_URL=
SHREDSTREAM_TOKEN=

# ── BAM Explorer ──────────────────────────────────────────────
BAM_EXPLORER_API=https://api.bam.dev

# ── Admin keypair (server-side only — NEVER expose to client) ─
# Used ONLY by /api/toggle-plugin server route.
# Get base58 key: solana-keygen show-private-key ~/.config/solana/id.json
# OR run: node -e "const k=require('@solana/web3.js').Keypair.generate();console.log(Buffer.from(k.secretKey).toString('base64'))"
# This is the market AUTHORITY keypair (the one that deployed the market).
# Users toggle plugin via their own wallet — this is only needed for the
# server-side fallback route.
AUTHORITY_KEYPAIR=

# ── Jito Stake Pool API ──────────────────────────────────────
STAKE_POOL_API=https://kobe.mainnet.jito.network
