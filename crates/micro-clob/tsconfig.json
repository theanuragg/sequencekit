{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["mocha", "node"]
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
